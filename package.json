{
  "name": "agent-harness",
  "version": "0.1.0",
  "description": "Lightweight TypeScript agent harness based on pi-mono",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "TEST_INTEGRATION=true vitest run tests/integration"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaza/openclaw-api-poc.git"
  },
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.55.3",
    "@mariozechner/pi-ai": "^0.55.3",
    "@mariozechner/pi-coding-agent": "^0.55.3",
    "@sinclair/typebox": "^0.34.48",
    "croner": "^10.0.1",
    "express": "^5.2.1",
    "multer": "^2.1.0",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
